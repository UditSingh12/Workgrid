{
  "name": "workgrid",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspaces run build",
    "start": "npm --workspace apps/api run start",
    "test": "npm --workspaces run test",
    "test:api": "npm --workspace apps/api run test",
    "test:web": "npm --workspace apps/web run test"
  }
}
