PORT=4000
NODE_ENV=development
APP_NAME=Workgrid API
CLIENT_URL=http://localhost:5173
DEMO_MODE=false
DEMO_WORKSPACE_NAME=Workgrid Demo Workspace
DEMO_OWNER_NAME=Demo Operator
DEMO_OWNER_EMAIL=demo@workgrid.app
